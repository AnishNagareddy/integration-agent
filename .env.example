# Copy to `.env`. The app is LIVE-only — it refuses to start without ANTHROPIC_API_KEY.

# Reasoning LLM (model-agnostic knobs; Claude by default).
LLM_PROVIDER=anthropic          # anthropic | openai | google_vertexai | ...
LLM_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=              # REQUIRED — also powers Claude's web-search tool

DATA_DIR=./.data

# (LangSmith tracing is a documented next-step, not wired. To enable it with zero code,
#  set the standard LANGSMITH_TRACING=true and LANGSMITH_API_KEY — LangChain auto-traces.)
